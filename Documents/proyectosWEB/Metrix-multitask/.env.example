# Copia este archivo como .env y ajusta los valores antes de levantar con Docker Compose.
# NUNCA commitear el archivo .env real — contiene secretos.

# REQUIRED — genera con: openssl rand -base64 32
METRIX_SECURITY_JWT_SECRET_KEY=

# MongoDB (local Docker o Atlas)
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/metrix_db

# Analytics microservice
METRIX_ANALYTICS_URL=http://analytics:8080/api/v1/analytics

# Google Cloud Storage (evidencias)
GCS_BUCKET_NAME=metrix-evidences
GCS_PROJECT_ID=
GCS_CREDENTIALS_PATH=classpath:gcp-service-account.json

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Logging (DEBUG para dev, INFO/WARN para prod)
LOG_LEVEL_MONGO=DEBUG
LOG_LEVEL_APP=DEBUG
